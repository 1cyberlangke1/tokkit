{
  "extends": "@tsconfig/node20/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "ignoreDeprecations": "6.0",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@cyberlangke/tokkit-core": ["packages/core/src/index.ts"],
      "@cyberlangke/tokkit-01-ai": ["packages/01-ai/src/index.ts"],
      "@cyberlangke/tokkit-minimax": ["packages/minimax/src/index.ts"],
      "@cyberlangke/tokkit-tiiuae": ["packages/tiiuae/src/index.ts"],
      "@cyberlangke/tokkit-eleutherai": ["packages/eleutherai/src/index.ts"],
      "@cyberlangke/tokkit-meituan-longcat": ["packages/meituan-longcat/src/index.ts"],
      "@cyberlangke/tokkit-xiaomi-mimo": ["packages/xiaomi-mimo/src/index.ts"],
      "@cyberlangke/tokkit-microsoft": ["packages/microsoft/src/index.ts"],
      "@cyberlangke/tokkit-mistral": ["packages/mistral/src/index.ts"],
      "@cyberlangke/tokkit-huggingface-tb": ["packages/huggingface-tb/src/index.ts"],
      "@cyberlangke/tokkit-allenai": ["packages/allenai/src/index.ts"],
      "@cyberlangke/tokkit-ibm-granite": ["packages/ibm-granite/src/index.ts"],
      "@cyberlangke/tokkit-ibm-research": ["packages/ibm-research/src/index.ts"],
      "@cyberlangke/tokkit-h2oai": ["packages/h2oai/src/index.ts"],
      "@cyberlangke/tokkit-nanbeige": ["packages/nanbeige/src/index.ts"],
      "@cyberlangke/tokkit-upstage": ["packages/upstage/src/index.ts"],
      "@cyberlangke/tokkit-openai": ["packages/openai/src/index.ts"],
      "@cyberlangke/tokkit-gsai-ml": ["packages/gsai-ml/src/index.ts"],
      "@cyberlangke/tokkit-bytedance-seed": ["packages/bytedance-seed/src/index.ts"],
      "@cyberlangke/tokkit-openbmb": ["packages/openbmb/src/index.ts"],
      "@cyberlangke/tokkit-qwen": ["packages/qwen/src/index.ts"],
      "@cyberlangke/tokkit-deepseek": ["packages/deepseek/src/index.ts"],
      "@cyberlangke/tokkit-glm": ["packages/glm/src/index.ts"],
      "@cyberlangke/tokkit-step": ["packages/step/src/index.ts"],
      "@cyberlangke/tokkit": ["packages/all/src/index.ts"]
    }
  },
  "include": [
    "packages/**/*.ts",
    "test/**/*.ts",
    "scripts/**/*.mjs",
    "scripts/**/*.d.ts",
    "vitest.config.ts"
  ],
  "exclude": ["node_modules", "dist", "coverage", "tmp", "packages/*/dist"]
}
