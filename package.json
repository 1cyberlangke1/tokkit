{
  "name": "tokkit",
  "version": "1.0.1",
  "description": "A tokenizer library for counting tokens.",
  "type": "module",
  "homepage": "https://github.com/1cyberlangke1/tokkit#readme",
  "bugs": {
    "url": "https://github.com/1cyberlangke1/tokkit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1cyberlangke1/tokkit.git"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "generate:builtins": "node scripts/generate-builtins.mjs",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{ts,js,json}\"",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\""
  },
  "keywords": [],
  "author": "cyberlangke",
  "license": "MIT",
  "devDependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@tsconfig/node20": "^20.1.9",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
